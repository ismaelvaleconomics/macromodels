    authors:
      - family-names: "Carlin"
        given-names: "Wendy"
      - family-names: "Soskice"
        given-names: "David"
    title: "Macroeconomics: Institutions, Instability, and the Financial System"
    year: 2023
    publisher:
      name: "Oxford University Press"
    edition: "2nd"

  - type: article
